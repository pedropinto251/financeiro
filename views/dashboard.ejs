<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Dashboard' %></title>
    <link rel="stylesheet" href="/css/app.css" />
    <script src="/js/fontawesome.min.js" defer></script>
  </head>
  <body>
    <header class="topbar">
      <div>
        <h1>Dashboard</h1>
        <p class="muted">Bem-vindo, <%= user && user.nome ? user.nome : 'utilizador' %></p>
      </div>
    </header>

    <main class="container">
      <%- include('partials/nav') %>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>
      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <section class="quick-actions">
        <button type="button" class="quick-btn quick-add quick-expense" data-type="expense">
          <i class="fa-solid fa-arrow-trend-down"></i>
          Despesa
        </button>
        <button type="button" class="quick-btn quick-add quick-income" data-type="income">
          <i class="fa-solid fa-arrow-trend-up"></i>
          Receita
        </button>
      </section>

      <section class="grid cards">
        <div class="card">
          <h2>Saldo mensal</h2>
          <p class="value"><%= (summary.income - summary.expense - summary.allocated).toFixed(2) %> €</p>
          <p class="muted">Receitas: <%= summary.income.toFixed(2) %> €</p>
          <p class="muted">Despesas: <%= summary.expense.toFixed(2) %> €</p>
          <% if (summary.allocated > 0) { %>
            <p class="muted">Alocado a objetivos: <%= summary.allocated.toFixed(2) %> €</p>
          <% } %>
        </div>
        <div class="card">
          <h2>Poupanca anual</h2>
          <p class="value"><%= (yearSummary.income - yearSummary.expense).toFixed(2) %> €</p>
          <p class="muted">Receitas: <%= yearSummary.income.toFixed(2) %> €</p>
          <p class="muted">Despesas: <%= yearSummary.expense.toFixed(2) %> €</p>
        </div>
        <div class="card">
          <h2>Gasto por categoria</h2>
          <% if (byCategory.length === 0) { %>
            <p class="muted">Sem despesas este mês.</p>
          <% } else { %>
            <div class="bars">
              <% byCategory.forEach((row) => { %>
                <div class="bar-row">
                  <div class="bar-label">
                    <span><%= row.nome %></span>
                    <strong><%= Number(row.total).toFixed(2) %> €</strong>
                  </div>
                  <div class="bar-track">
                    <span class="bar-fill" style="width:<%= row.percent %>%"></span>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
        <div class="card">
          <h2>Objetivos</h2>
          <% if (!goals || goals.length === 0) { %>
            <p class="muted">Ainda nao existem objetivos.</p>
          <% } else { %>
            <p class="muted">Saldo corrente: <%= Number(availableTotal || 0).toFixed(2) %> €</p>
            <p class="muted">Poupancas alocadas: <%= Number(allocatedTotal || 0).toFixed(2) %> €</p>
            <ul class="list">
              <% goals.forEach((goal) => { %>
                <% const target = Number(goal.valor_objetivo || 0); %>
                <% const allocated = Number(goal.total_alocado || 0); %>
                <% const percent = target > 0 ? Math.min(100, Math.round((allocated / target) * 100)) : 0; %>
                <li class="<%= percent >= 100 ? 'goal-complete' : '' %>">
                  <div>
                    <strong><%= goal.nome %></strong>
                    <div class="tx-desc">Alocado: <%= allocated.toFixed(2) %> € / <%= target.toFixed(2) %> €</div>
                    <div class="bar-track" style="margin-top:0.35rem;">
                      <span class="bar-fill" style="width:<%= percent %>%"></span>
                    </div>
                    <% if (percent >= 100) { %>
                      <div class="goal-badge">Objetivo cumprido! Parabens!</div>
                    <% } %>
                  </div>
                  <div class="tx-actions">
                    <button
                      type="button"
                      class="icon-btn goal-allocate"
                      data-goal="<%= goal.id %>"
                      data-name="<%= goal.nome %>"
                      <%= Number(availableTotal || 0) <= 0 ? 'disabled' : '' %>
                    >
                      Alocar
                    </button>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </section>
    </main>

    <div class="modal-overlay" id="quick-tx-modal">
      <div class="modal">
        <div class="modal-header">
          <h2>Novo movimento</h2>
          <button class="modal-close" type="button" id="quick-close">Fechar</button>
        </div>
        <form method="POST" action="/transactions" enctype="multipart/form-data" class="stack" id="quick-tx-form">
          <label class="field">
            <span>Tipo</span>
            <select name="type" id="quick-tx-type" required>
              <option value="expense">Despesa</option>
              <option value="income">Receita</option>
            </select>
          </label>
          <label class="field">
            <span>Valor</span>
            <input name="amount" type="number" step="0.01" required />
          </label>
          <label class="field">
            <span>Data</span>
            <input name="date" id="quick-tx-date" type="date" required />
          </label>
          <label class="field">
            <span>Descricao</span>
            <input name="description" type="text" />
          </label>
          <label class="field">
            <span>Categoria</span>
            <input type="text" id="quick-category-filter" placeholder="Pesquisar categoria..." />
            <select name="category_id" id="quick-category">
              <option value="">Sem categoria</option>
              <% categories.forEach((cat) => { %>
                <option value="<%= cat.id %>"><%= cat.nome %> (<%= cat.tipo === 'income' ? 'Receita' : 'Despesa' %>)</option>
              <% }) %>
            </select>
          </label>
          <label class="field">
            <span>Documento</span>
            <input name="documento" type="file" />
          </label>
          <button type="submit">Guardar</button>
        </form>
      </div>
    </div>

    <div class="modal-overlay" id="allocation-modal">
      <div class="modal">
        <div class="modal-header">
          <h2 id="allocation-title">Alocar poupanca</h2>
          <button type="button" class="modal-close" data-close="allocation-modal">Fechar</button>
        </div>
        <form method="POST" action="/goals/allocate" class="stack" id="allocation-form">
          <input type="hidden" name="back_to" value="/dashboard" />
          <label class="field">
            <span>Objetivo</span>
            <select name="goal_id" id="allocation-goal" required>
              <% goals.forEach((goal) => { %>
                <option value="<%= goal.id %>"><%= goal.nome %></option>
              <% }) %>
            </select>
          </label>
          <label class="field">
            <span>Valor a alocar (€)</span>
            <input name="amount" id="allocation-amount" type="number" step="0.01" min="0.01" required />
            <small class="muted">Disponivel: <%= Number(availableTotal || 0).toFixed(2) %> €</small>
          </label>
          <label class="field">
            <span>Data</span>
            <input name="date" id="allocation-date" type="date" required />
          </label>
          <label class="field">
            <span>Nota (opcional)</span>
            <input name="note" type="text" />
          </label>
          <button type="submit">Alocar</button>
        </form>
      </div>
    </div>

    <script>
      const today = new Date();
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      const allocationDate = document.getElementById('allocation-date');
      if (allocationDate) allocationDate.value = `${yyyy}-${mm}-${dd}`;

      const allocationModal = document.getElementById('allocation-modal');
      const allocationTitle = document.getElementById('allocation-title');
      const allocationSelect = document.getElementById('allocation-goal');
      const allocationAmount = document.getElementById('allocation-amount');
      const available = Number('<%= Number(availableTotal || 0).toFixed(2) %>');

      if (allocationAmount && available > 0) {
        allocationAmount.max = available.toFixed(2);
      }

      const openModal = (modal) => modal && modal.classList.add('open');
      const closeModal = (modal) => modal && modal.classList.remove('open');

      document.querySelectorAll('.goal-allocate').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (available <= 0) return;
          const id = btn.dataset.goal;
          const name = btn.dataset.name || 'Objetivo';
          if (allocationTitle) allocationTitle.textContent = `Alocar para: ${name}`;
          if (allocationSelect) allocationSelect.value = id;
          openModal(allocationModal);
        });
      });

      document.querySelectorAll('[data-close]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.close;
          closeModal(document.getElementById(id));
        });
      });

      if (allocationModal) {
        allocationModal.addEventListener('click', (e) => {
          if (e.target === allocationModal) closeModal(allocationModal);
        });
      }
      const quickModal = document.getElementById('quick-tx-modal');
      const quickClose = document.getElementById('quick-close');
      const quickType = document.getElementById('quick-tx-type');
      const quickDate = document.getElementById('quick-tx-date');
      if (quickDate) {
        quickDate.value = `${yyyy}-${mm}-${dd}`;
      }

      document.querySelectorAll('.quick-add').forEach((btn) => {
        btn.addEventListener('click', () => {
          const type = btn.dataset.type || 'expense';
          if (quickType) quickType.value = type;
          if (quickModal) quickModal.classList.add('open');
        });
      });

      if (quickClose && quickModal) {
        quickClose.addEventListener('click', () => quickModal.classList.remove('open'));
        quickModal.addEventListener('click', (e) => {
          if (e.target === quickModal) quickModal.classList.remove('open');
        });
      }

      const wireCategoryFilter = (inputId, selectId) => {
        const input = document.getElementById(inputId);
        const select = document.getElementById(selectId);
        if (!input || !select) return;
        const options = Array.from(select.options).map(opt => ({
          value: opt.value,
          text: opt.textContent,
        }));
        input.addEventListener('input', () => {
          const q = input.value.trim().toLowerCase();
          select.innerHTML = '';
          options.forEach((opt) => {
            if (!q || opt.text.toLowerCase().includes(q)) {
              const optionEl = document.createElement('option');
              optionEl.value = opt.value;
              optionEl.textContent = opt.text;
              select.appendChild(optionEl);
            }
          });
        });
      };

      wireCategoryFilter('quick-category-filter', 'quick-category');

      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeModal(allocationModal);
          if (quickModal) quickModal.classList.remove('open');
        }
      });
    </script>
  </body>
</html>
