<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Dashboard' %></title>
    <link rel="stylesheet" href="/css/app.css" />
    <script src="/js/fontawesome.min.js" defer></script>
  </head>
  <body>
    <header class="topbar">
      <div>
        <h1>Dashboard</h1>
        <p class="muted">Bem-vindo, <%= user && user.nome ? user.nome : 'utilizador' %></p>
      </div>
      <form method="GET" action="/logout">
        <button type="submit" class="secondary">Sair</button>
      </form>
    </header>

    <main class="container">
      <%- include('partials/nav') %>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>
      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <section class="grid cards">
        <div class="card">
          <h2>Saldo mensal</h2>
          <p class="value"><%= (summary.income - summary.expense).toFixed(2) %> €</p>
          <p class="muted">Receitas: <%= summary.income.toFixed(2) %> €</p>
          <p class="muted">Despesas: <%= summary.expense.toFixed(2) %> €</p>
        </div>
        <div class="card">
          <h2>Poupanca anual</h2>
          <p class="value"><%= (yearSummary.income - yearSummary.expense).toFixed(2) %> €</p>
          <p class="muted">Receitas: <%= yearSummary.income.toFixed(2) %> €</p>
          <p class="muted">Despesas: <%= yearSummary.expense.toFixed(2) %> €</p>
        </div>
        <div class="card">
          <h2>Gasto por categoria</h2>
          <% if (byCategory.length === 0) { %>
            <p class="muted">Sem despesas este mês.</p>
          <% } else { %>
            <div class="bars">
              <% byCategory.forEach((row) => { %>
                <div class="bar-row">
                  <div class="bar-label">
                    <span><%= row.nome %></span>
                    <strong><%= Number(row.total).toFixed(2) %> €</strong>
                  </div>
                  <div class="bar-track">
                    <span class="bar-fill" style="width:<%= row.percent %>%"></span>
                  </div>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
        <div class="card">
          <h2>Evolucao 6 meses</h2>
          <div class="spark">
            <% series.forEach((row) => { %>
              <div class="spark-col">
                <span class="spark-bar" style="height:<%= Math.min(100, Math.max(6, Math.round(Math.abs(row.total_income - row.total_expense) / 10))) %>%"></span>
                <small><%= row.mes.slice(5,7) %>/<%= row.mes.slice(2,4) %></small>
              </div>
            <% }) %>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
