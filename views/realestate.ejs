<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Imoveis' %></title>
    <link rel="stylesheet" href="/css/app.css" />
    <script src="/js/fontawesome.min.js" defer></script>
  </head>
  <body>
    <header class="topbar">
      <div>
        <h1>Imoveis</h1>
        <p class="muted">Teste rapido com Imovirtual, Supercasa e Casa Certa</p>
      </div>
    </header>

    <main class="container">
      <%- include('partials/nav') %>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>
      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <section class="card estate-hero">
        <div class="estate-hero-header">
          <div class="estate-hero-title">
            <span class="estate-hero-kicker">Agregador Imobiliario</span>
            <h2>Pesquisa unificada e inteligente</h2>
            <p class="muted">Cruza fontes, reduz repetidos e traz tudo num so painel.</p>
          </div>
          <div class="estate-hero-actions">
            <div class="estate-kpi">
              <span class="estate-kpi-label">Imoveis</span>
              <span class="estate-kpi-value" id="estate-total">0</span>
            </div>
            <div class="estate-actions">
              <button class="quick-btn" type="button" id="estate-refresh">
                <i class="fa-solid fa-rotate"></i>
                Atualizar
              </button>
              <button class="quick-btn" type="button" id="estate-prev">
                <i class="fa-solid fa-chevron-left"></i>
                Pagina anterior
              </button>
              <button class="quick-btn" type="button" id="estate-next">
                <i class="fa-solid fa-chevron-right"></i>
                Proxima pagina
              </button>
            </div>
          </div>
        </div>

        <div class="estate-filters-panel">
          <div class="estate-filter-group">
            <div class="estate-filter-title estate-filter-title-row">
              <span>Localizacao</span>
              <button class="ghost-btn" type="button" id="estate-build-locations">Atualizar lista</button>
              <span class="estate-filter-status" id="estate-build-status"></span>
            </div>
            <div class="estate-filter-row">
              <label class="estate-field">
                <span>Distrito</span>
                <select id="estate-district"></select>
              </label>
              <label class="estate-field">
                <span>Concelho</span>
                <select id="estate-council"></select>
              </label>
              <label class="estate-field">
                <span>Pagina</span>
                <input type="number" id="estate-page" min="1" value="1" />
              </label>
            </div>
          </div>

          <div class="estate-filter-group">
            <div class="estate-filter-title">Preco</div>
            <div class="estate-filter-row">
              <label class="estate-field">
                <span>Minimo</span>
                <input type="number" id="estate-price-min" min="0" placeholder="0" />
              </label>
              <label class="estate-field">
                <span>Maximo</span>
                <input type="number" id="estate-price-max" min="0" placeholder="1000000" />
              </label>
            </div>
          </div>

          <div class="estate-filter-group">
            <div class="estate-filter-title">Tipologia e Texto</div>
            <div class="estate-filter-row">
              <label class="estate-field">
                <span>Tipologia</span>
                <select id="estate-rooms">
                  <option value="">Todas</option>
                  <option value="1">T1</option>
                  <option value="2">T2</option>
                  <option value="3">T3</option>
                  <option value="4">T4+</option>
                </select>
              </label>
              <label class="estate-field estate-field-grow">
                <span>Pesquisa</span>
                <input type="text" id="estate-search" placeholder="ex: varanda, praia" />
              </label>
            </div>
          </div>

          <div class="estate-filter-group">
            <div class="estate-filter-title">Ordenacao</div>
            <div class="estate-filter-row">
              <label class="estate-field estate-field-grow">
                <span>Ordenar por</span>
                <select id="estate-sort">
                  <option value="relevance">Relevancia</option>
                  <option value="price_asc">Preco (baixo → alto)</option>
                  <option value="price_desc">Preco (alto → baixo)</option>
                  <option value="area_asc">Area (baixo → alto)</option>
                  <option value="area_desc">Area (alto → baixo)</option>
                  <option value="rooms_desc">Tipologia (alto → baixo)</option>
                  <option value="rooms_asc">Tipologia (baixo → alto)</option>
                  <option value="date_desc">Mais recente</option>
                  <option value="date_asc">Mais antigo</option>
                  <option value="title_asc">Titulo (A → Z)</option>
                  <option value="title_desc">Titulo (Z → A)</option>
                </select>
              </label>
            </div>
          </div>
        </div>

        <div class="estate-tabs-bar estate-tabs">
          <button class="ghost-btn is-active" type="button" data-view="combined">Agregado</button>
          <button class="ghost-btn" type="button" data-view="imovirtual">Imovirtual</button>
          <button class="ghost-btn" type="button" data-view="supercasa">Supercasa</button>
          <button class="ghost-btn" type="button" data-view="casacerta">Casa Certa</button>
          <button class="ghost-btn" type="button" data-view="casayes">Casa Yes</button>
          <button class="ghost-btn" type="button" data-view="greenacres">Green Acres</button>
        </div>
        <p class="estate-note">
          Nota: o Imovirtual usa um buildId no URL. Se falhar, tera de atualizar o link.
        </p>
      </section>

      <section class="estate-content" id="estate-content">
        <div class="estate-status">A carregar...</div>
      </section>

      <section class="estate-footer">
        <button class="quick-btn" type="button" id="estate-prev-bottom">
          <i class="fa-solid fa-chevron-left"></i>
          Pagina anterior
        </button>
        <button class="quick-btn" type="button" id="estate-next-bottom">
          <i class="fa-solid fa-chevron-right"></i>
          Proxima pagina
        </button>
      </section>
    </main>

    <script>
      (() => {
        const content = document.getElementById('estate-content');
        const total = document.getElementById('estate-total');
        const refreshBtn = document.getElementById('estate-refresh');
        const prevBtn = document.getElementById('estate-prev');
        const nextBtn = document.getElementById('estate-next');
        const prevBottomBtn = document.getElementById('estate-prev-bottom');
        const nextBottomBtn = document.getElementById('estate-next-bottom');
        const districtInput = document.getElementById('estate-district');
        const councilInput = document.getElementById('estate-council');
        const pageInput = document.getElementById('estate-page');
        const buildLocationsBtn = document.getElementById('estate-build-locations');
        const buildStatus = document.getElementById('estate-build-status');
        const priceMinInput = document.getElementById('estate-price-min');
        const priceMaxInput = document.getElementById('estate-price-max');
        const roomsInput = document.getElementById('estate-rooms');
        const searchInput = document.getElementById('estate-search');
        const sortInput = document.getElementById('estate-sort');

        let locationData = {
          districts: [
            { name: 'Aveiro', slug: 'aveiro' },
            { name: 'Porto', slug: 'porto' },
            { name: 'Lisboa', slug: 'lisboa' },
          ],
          byDistrict: {
            aveiro: [
              { name: 'Aveiro', slug: 'aveiro' },
              { name: 'Espinho', slug: 'espinho' },
              { name: 'Ilhavo', slug: 'ilhavo' },
            ],
            porto: [
              { name: 'Porto', slug: 'porto' },
              { name: 'Vila Nova de Gaia', slug: 'vila-nova-de-gaia' },
              { name: 'Matosinhos', slug: 'matosinhos' },
            ],
            lisboa: [
              { name: 'Lisboa', slug: 'lisboa' },
              { name: 'Cascais', slug: 'cascais' },
              { name: 'Sintra', slug: 'sintra' },
            ],
          },
        };

        const buildOptionsFromList = (select, items, selectedSlug) => {
          select.innerHTML = '';
          items.forEach((item) => {
            const opt = document.createElement('option');
            opt.value = item.slug;
            opt.textContent = item.name;
            if (selectedSlug && item.slug === selectedSlug) opt.selected = true;
            select.appendChild(opt);
          });
        };

        const syncDistrictOptions = () => {
          const currentDistrict = slugify(districtInput.value || 'aveiro');
          buildOptionsFromList(districtInput, locationData.districts, currentDistrict);
          refreshCouncils();
        };

        const slugify = (value) =>
          String(value || '')
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '')
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-+|-+$/g, '');

        const refreshCouncils = () => {
          const key = slugify(districtInput.value);
          const councils = locationData.byDistrict[key] || [];
          const current = slugify(councilInput.value || (councils[0] && councils[0].name));
          buildOptionsFromList(councilInput, councils, current);
        };

        districtInput.addEventListener('change', refreshCouncils);
        districtInput.addEventListener('blur', refreshCouncils);
        syncDistrictOptions();

        const loadLocations = () =>
          fetch('/data/portugal-locations.json')
            .then((res) => (res.ok ? res.json() : null))
            .then((payload) => {
              if (!payload || !payload.districts || !payload.byDistrict) return false;
              locationData = payload;
              syncDistrictOptions();
              return true;
            })
            .catch(() => false);

        loadLocations();

        buildLocationsBtn.addEventListener('click', async () => {
          buildLocationsBtn.disabled = true;
          buildStatus.textContent = 'A atualizar...';
          try {
            const res = await fetch('/realestate/locations/build', { method: 'POST' });
            const payload = await res.json();
            if (!res.ok || !payload.ok) {
              buildStatus.textContent = 'Falhou ao atualizar.';
            } else {
              const ok = await loadLocations();
              buildStatus.textContent = ok ? 'Lista atualizada.' : 'Atualizado mas sem dados.';
            }
          } catch (err) {
            buildStatus.textContent = 'Erro ao atualizar.';
          } finally {
            setTimeout(() => {
              buildStatus.textContent = '';
              buildLocationsBtn.disabled = false;
            }, 3000);
          }
        });

        const renderCard = (item) => {
          const card = document.createElement('article');
          card.className = 'card estate-card';

          const media = document.createElement('div');
          media.className = 'estate-media';
          if (item.image) {
            media.style.backgroundImage = `url(${item.image})`;
          } else {
            media.classList.add('estate-media-empty');
          }

          const body = document.createElement('div');
          body.className = 'estate-body';

          const source = document.createElement('span');
          source.className = 'estate-source';
          if (Array.isArray(item.sources) && item.sources.length) {
            source.textContent = item.sources.join(' + ');
          } else {
            source.textContent = item.source;
          }

          const title = document.createElement('h3');
          title.textContent = item.title || 'Imovel';

          const meta = document.createElement('div');
          meta.className = 'estate-meta';
          const metaItems = [item.price, item.rooms, item.area];
          if (Array.isArray(item.extras)) metaItems.push(...item.extras);
          metaItems.filter(Boolean).forEach((txt) => {
            const span = document.createElement('span');
            span.textContent = txt;
            meta.appendChild(span);
          });

          body.appendChild(source);
          body.appendChild(title);
          body.appendChild(meta);
          if (item.description) {
            const desc = document.createElement('p');
            desc.className = 'estate-desc';
            desc.textContent = item.description;
            body.appendChild(desc);
          }

          const link = document.createElement('a');
          link.className = 'estate-link';
          link.textContent = 'Abrir anuncio';
          link.href = item.url || (Array.isArray(item.urls) && item.urls[0]) || '#';
          link.target = '_blank';
          link.rel = 'noreferrer';

          card.appendChild(media);
          card.appendChild(body);
          if (item.url || (Array.isArray(item.urls) && item.urls.length)) card.appendChild(link);

          return card;
        };

        const renderSection = (title, items, id, method) => {
          const wrapper = document.createElement('div');
          wrapper.className = 'estate-section';
          if (id) wrapper.id = id;

          const heading = document.createElement('h2');
          heading.textContent = `${title} (${items.length})`;
          if (method) {
            const badge = document.createElement('span');
            badge.className = 'estate-method';
            badge.textContent = method;
            heading.appendChild(badge);
          }

          const grid = document.createElement('div');
          grid.className = 'estate-grid';

          items.forEach((item) => {
            grid.appendChild(renderCard(item));
          });

          wrapper.appendChild(heading);
          wrapper.appendChild(grid);
          return wrapper;
        };

        const parsePrice = (value) => {
          if (!value) return null;
          const num = String(value).replace(/[^\d]/g, '');
          if (!num) return null;
          return Number(num);
        };

        const parseRooms = (value) => {
          if (!value) return null;
          const match = String(value).match(/(\d+)/);
          return match ? Number(match[1]) : null;
        };

        const parseArea = (value) => {
          if (!value) return null;
          const num = String(value).replace(/[^\d]/g, '');
          if (!num) return null;
          return Number(num);
        };

        const parsePublishedAt = (value) => {
          if (!value) return null;
          const ts = Date.parse(value);
          return Number.isFinite(ts) ? ts : null;
        };

        const applySort = (items) => {
          const mode = sortInput.value || 'relevance';
          const list = [...items];
          const compareText = (a, b, field, dir) => {
            const av = String(a[field] || '').toLowerCase();
            const bv = String(b[field] || '').toLowerCase();
            if (av === bv) return 0;
            return dir === 'asc' ? (av > bv ? 1 : -1) : (av < bv ? 1 : -1);
          };
          switch (mode) {
            case 'price_asc':
              return list.sort((a, b) => (parsePrice(a.price) ?? Infinity) - (parsePrice(b.price) ?? Infinity));
            case 'price_desc':
              return list.sort((a, b) => (parsePrice(b.price) ?? -Infinity) - (parsePrice(a.price) ?? -Infinity));
            case 'area_asc':
              return list.sort((a, b) => (parseArea(a.area) ?? Infinity) - (parseArea(b.area) ?? Infinity));
            case 'area_desc':
              return list.sort((a, b) => (parseArea(b.area) ?? -Infinity) - (parseArea(a.area) ?? -Infinity));
            case 'rooms_asc':
              return list.sort((a, b) => (parseRooms(a.rooms) ?? Infinity) - (parseRooms(b.rooms) ?? Infinity));
            case 'rooms_desc':
              return list.sort((a, b) => (parseRooms(b.rooms) ?? -Infinity) - (parseRooms(a.rooms) ?? -Infinity));
            case 'date_desc':
              return list.sort((a, b) => (parsePublishedAt(b.publishedAt) ?? -Infinity) - (parsePublishedAt(a.publishedAt) ?? -Infinity));
            case 'date_asc':
              return list.sort((a, b) => (parsePublishedAt(a.publishedAt) ?? Infinity) - (parsePublishedAt(b.publishedAt) ?? Infinity));
            case 'title_asc':
              return list.sort((a, b) => compareText(a, b, 'title', 'asc'));
            case 'title_desc':
              return list.sort((a, b) => compareText(a, b, 'title', 'desc'));
            default:
              return list;
          }
        };

        const applyFilters = (items) => {
          const min = Number(priceMinInput.value || 0) || 0;
          const max = Number(priceMaxInput.value || 0) || 0;
          const rooms = roomsInput.value ? Number(roomsInput.value) : null;
          const text = (searchInput.value || '').trim().toLowerCase();

          return items.filter((item) => {
            const priceNum = parsePrice(item.price);
            if (min && (!priceNum || priceNum < min)) return false;
            if (max && (!priceNum || priceNum > max)) return false;

            if (rooms !== null) {
              const itemRooms = parseRooms(item.rooms);
              if (!itemRooms) return false;
              if (rooms >= 4 && itemRooms < 4) return false;
              if (rooms < 4 && itemRooms !== rooms) return false;
            }

            if (text) {
              const haystack = `${item.title || ''} ${item.description || ''}`.toLowerCase();
              if (!haystack.includes(text)) return false;
            }

          return true;
        });
        };

        let latestData = null;
        let currentView = 'combined';
        const renderFromData = (data) => {
          if (!data) return;
          const imovirtual = applySort(applyFilters(Array.isArray(data.imovirtual) ? data.imovirtual : []));
          const supercasa = applySort(applyFilters(Array.isArray(data.supercasa) ? data.supercasa : []));
          const casacerta = applySort(applyFilters(Array.isArray(data.casacerta) ? data.casacerta : []));
          const casayes = applySort(applyFilters(Array.isArray(data.casayes) ? data.casayes : []));
          const greenacres = applySort(applyFilters(Array.isArray(data.greenacres) ? data.greenacres : []));
          const combined = applySort(applyFilters(Array.isArray(data.combined) ? data.combined : []));
          const totalCount = combined.length;
          total.textContent = String(totalCount);

          content.innerHTML = '';
          if (Array.isArray(data.warnings) && data.warnings.length) {
            const warn = document.createElement('div');
            warn.className = 'estate-status error';
            const lines = data.warnings.map((w) => {
              if (typeof w === 'string') return w;
              const parts = [w.source || 'fonte', w.error || 'erro'];
              if (w.status) parts.push(`status ${w.status}`);
              if (w.statusText) parts.push(w.statusText);
              if (w.bodySnippet) parts.push(w.bodySnippet.replace(/\n/g, ' ').slice(0, 140));
              return parts.join(' | ');
            });
            warn.textContent = `Aviso: ${lines.join(' / ')}`;
            content.appendChild(warn);
          }
          const sections = document.createElement('div');
          sections.className = 'estate-sections';
          sections.appendChild(renderSection('Agregado', combined, 'estate-combined', 'dedupe'));
          sections.appendChild(renderSection('Imovirtual', imovirtual, 'estate-imovirtual', data.methods && data.methods.imovirtual));
          sections.appendChild(renderSection('Supercasa', supercasa, 'estate-supercasa', data.methods && data.methods.supercasa));
          sections.appendChild(renderSection('Casa Certa', casacerta, 'estate-casacerta', data.methods && data.methods.casacerta));
          sections.appendChild(renderSection('Casa Yes', casayes, 'estate-casayes', data.methods && data.methods.casayes));
          sections.appendChild(renderSection('Green Acres', greenacres, 'estate-greenacres', data.methods && data.methods.greenacres));
          content.appendChild(sections);
          const setView = (view) => {
            currentView = view || currentView || 'combined';
            const map = {
              combined: 'estate-combined',
              imovirtual: 'estate-imovirtual',
              supercasa: 'estate-supercasa',
              casacerta: 'estate-casacerta',
              casayes: 'estate-casayes',
              greenacres: 'estate-greenacres',
            };
            Object.values(map).forEach((id) => {
              const section = document.getElementById(id);
              if (section) section.style.display = id === map[currentView] ? 'block' : 'none';
            });
            document.querySelectorAll('.estate-tabs [data-view]').forEach((btn) => {
              btn.classList.toggle('is-active', btn.getAttribute('data-view') === currentView);
            });
          };
          setView(currentView || 'combined');
        };

        const load = async () => {
          content.innerHTML = '<div class="estate-status">A carregar...</div>';
          try {
            const district = districtInput.value.trim() || 'aveiro';
            const council = councilInput.value.trim() || 'espinho';
            const page = Math.max(1, Number(pageInput.value || 1));
            const res = await fetch(`/realestate/data?district=${encodeURIComponent(district)}&council=${encodeURIComponent(council)}&page=${page}`);
            if (!res.ok) throw new Error('Falha ao carregar');
            const data = await res.json();
            latestData = data;
            renderFromData(latestData);
          } catch (err) {
            content.innerHTML = '<div class="estate-status error">Erro ao carregar dados.</div>';
          }
        };

        refreshBtn.addEventListener('click', load);
        [priceMinInput, priceMaxInput, roomsInput, searchInput, sortInput].forEach((el) => {
          el.addEventListener('input', () => renderFromData(latestData));
          el.addEventListener('change', () => renderFromData(latestData));
        });
        prevBtn.addEventListener('click', () => {
          const current = Math.max(1, Number(pageInput.value || 1));
          const next = Math.max(1, current - 1);
          pageInput.value = String(next);
          load();
        });
        nextBtn.addEventListener('click', () => {
          const current = Math.max(1, Number(pageInput.value || 1));
          pageInput.value = String(current + 1);
          load();
        });
        prevBottomBtn.addEventListener('click', () => {
          const current = Math.max(1, Number(pageInput.value || 1));
          const next = Math.max(1, current - 1);
          pageInput.value = String(next);
          load();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        nextBottomBtn.addEventListener('click', () => {
          const current = Math.max(1, Number(pageInput.value || 1));
          pageInput.value = String(current + 1);
          load();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        document.querySelectorAll('[data-view]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const view = btn.getAttribute('data-view');
            const target = document.getElementById(`estate-${view}`);
            if (target) {
              currentView = view || 'combined';
              document.querySelectorAll('.estate-section').forEach((section) => {
                section.style.display = section === target ? 'block' : 'none';
              });
              document.querySelectorAll('.estate-tabs [data-view]').forEach((tab) => {
                tab.classList.toggle('is-active', tab === btn);
              });
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          });
        });
        load();
      })();
    </script>
  </body>
</html>
