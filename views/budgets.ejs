<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Budgets' %></title>
    <link rel="stylesheet" href="/css/app.css" />
    <script src="/js/fontawesome.min.js" defer></script>
  </head>
  <body>
    <header class="topbar">
      <div>
        <h1>Budgets</h1>
        <p class="muted">Defina limites por categoria e mes.</p>
      </div>
    </header>

    <main class="container">
      <%- include('partials/nav') %>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>
      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <section class="grid two">
        <div class="card">
          <h2>Definir budget</h2>
          <form method="POST" action="/budgets" class="stack">
            <label class="field">
              <span>Categoria</span>
              <select name="category_id" required>
                <% categories.forEach((cat) => { %>
                  <option value="<%= cat.id %>"><%= cat.nome %> (<%= cat.tipo === 'income' ? 'Receita' : 'Despesa' %>)</option>
                <% }) %>
              </select>
            </label>
            <label class="field">
              <span>Mes</span>
              <input name="month" id="budget-month" type="month" required />
            </label>
            <label class="field">
              <span>Valor</span>
              <input name="amount" type="number" step="0.01" required />
            </label>
            <button type="submit">Guardar</button>
          </form>
        </div>

        <div class="card">
          <h2>Budgets atuais</h2>
          <% if (budgets.length === 0) { %>
            <p class="muted">Ainda nao existem budgets.</p>
          <% } else { %>
            <ul class="list">
              <% budgets.forEach((row) => { %>
                <li data-id="<%= row.id %>" data-category="<%= row.categoria_id %>" data-month="<%= row.mes %>" data-amount="<%= row.valor %>">
                  <span><span class="month" data-date="<%= row.mes %>"></span> - <%= row.categoria_nome %></span>
                  <div class="tx-actions">
                    <strong><%= Number(row.valor).toFixed(2) %> €</strong>
                    <button type="button" class="icon-btn budget-edit">Editar</button>
                    <form method="POST" action="/budgets/delete" class="inline-form">
                      <input type="hidden" name="id" value="<%= row.id %>" />
                      <button type="submit" class="icon-btn danger">Apagar</button>
                    </form>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </section>
    </main>

    <div class="modal-overlay" id="budget-edit-modal">
      <div class="modal">
        <div class="modal-header">
          <h2>Editar budget</h2>
          <button type="button" class="modal-close" data-close="budget-edit-modal">Fechar</button>
        </div>
        <form method="POST" action="/budgets/update" class="stack" id="budget-edit-form">
          <input type="hidden" name="id" id="budget-edit-id" />
          <label class="field">
            <span>Categoria</span>
            <select name="category_id" id="budget-edit-category" required>
              <% categories.forEach((cat) => { %>
                <option value="<%= cat.id %>"><%= cat.nome %> (<%= cat.tipo === 'income' ? 'Receita' : 'Despesa' %>)</option>
              <% }) %>
            </select>
          </label>
          <label class="field">
            <span>Mes</span>
            <input name="month" id="budget-edit-month" type="month" required />
          </label>
          <label class="field">
            <span>Valor</span>
            <input name="amount" id="budget-edit-amount" type="number" step="0.01" required />
          </label>
          <button type="submit">Guardar</button>
        </form>
      </div>
    </div>

    <script>
      const monthInput = document.getElementById('budget-month');
      if (monthInput) {
        const today = new Date();
        const yyyy = today.getFullYear();
        const mm = String(today.getMonth() + 1).padStart(2, '0');
        monthInput.value = `${yyyy}-${mm}`;
      }

      const monthFormatter = new Intl.DateTimeFormat('pt-PT', {
        month: '2-digit',
        year: 'numeric',
      });
      document.querySelectorAll('.month').forEach((el) => {
        const raw = el.dataset.date;
        const parsed = raw ? new Date(raw) : null;
        el.textContent = parsed ? monthFormatter.format(parsed) : '';
      });

      const budgetModal = document.getElementById('budget-edit-modal');
      const budgetId = document.getElementById('budget-edit-id');
      const budgetCategory = document.getElementById('budget-edit-category');
      const budgetMonth = document.getElementById('budget-edit-month');
      const budgetAmount = document.getElementById('budget-edit-amount');

      const openModal = (modal) => modal && modal.classList.add('open');
      const closeModal = (modal) => modal && modal.classList.remove('open');

      document.querySelectorAll('.budget-edit').forEach((btn) => {
        btn.addEventListener('click', () => {
          const li = btn.closest('li');
          if (!li) return;
          if (budgetId) budgetId.value = li.dataset.id || '';
          if (budgetCategory) budgetCategory.value = li.dataset.category || '';
          if (budgetMonth) budgetMonth.value = li.dataset.month ? li.dataset.month.slice(0, 7) : '';
          if (budgetAmount) budgetAmount.value = li.dataset.amount || '';
          openModal(budgetModal);
        });
      });

      document.querySelectorAll('[data-close]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.close;
          closeModal(document.getElementById(id));
        });
      });

      if (budgetModal) {
        budgetModal.addEventListener('click', (e) => {
          if (e.target === budgetModal) closeModal(budgetModal);
        });
      }
      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeModal(budgetModal);
      });
    </script>
  </body>
</html>
