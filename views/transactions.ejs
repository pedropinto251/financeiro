<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Movimentos' %></title>
    <link rel="stylesheet" href="/css/app.css" />
    <script src="/js/fontawesome.min.js" defer></script>
  </head>
  <body>
    <header class="topbar">
      <div>
        <h1>Movimentos</h1>
        <p class="muted">Registe receitas e despesas.</p>
      </div>
    </header>

    <main class="container">
      <%- include('partials/nav') %>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>
      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <section class="grid two">
        <div class="card tx-form-card">
          <h2>Adicionar movimento</h2>
          <form method="POST" action="/transactions" enctype="multipart/form-data" class="stack" id="tx-form">
            <label class="field">
              <span>Tipo</span>
              <select name="type" id="tx-type" required>
                <option value="expense">Despesa</option>
                <option value="income">Receita</option>
              </select>
            </label>
            <label class="field">
              <span>Valor</span>
              <input name="amount" type="number" step="0.01" required />
            </label>
            <label class="field">
              <span>Data</span>
              <input name="date" id="tx-date" type="date" required />
            </label>
            <label class="field">
              <span>Descricao</span>
              <input name="description" type="text" />
            </label>
            <label class="field">
              <span>Categoria</span>
              <input type="text" id="tx-category-filter" placeholder="Pesquisar categoria..." />
              <select name="category_id" id="tx-category">
                <option value="">Sem categoria</option>
                <% categories.forEach((cat) => { %>
                  <option value="<%= cat.id %>"><%= cat.nome %> (<%= cat.tipo === 'income' ? 'Receita' : 'Despesa' %>)</option>
                <% }) %>
              </select>
            </label>
            <label class="field">
              <span>Documento</span>
              <input name="documento" type="file" />
            </label>
            <button type="submit">Guardar</button>
          </form>
        </div>

        <div class="card">
          <h2>Movimentos</h2>
          <div class="grid two" style="margin-bottom: 0.75rem;">
            <form method="GET" action="/reports/export" class="inline-form">
              <input type="hidden" name="period" value="month" />
              <label class="field">
                <span>Exportar mes</span>
                <input id="export-month" name="month" type="month" required />
              </label>
              <button type="submit" class="secondary">Excel</button>
            </form>
            <form method="GET" action="/reports/export" class="inline-form">
              <input type="hidden" name="period" value="year" />
              <label class="field">
                <span>Exportar ano</span>
                <input id="export-year" name="year" type="number" min="2000" max="2100" required />
              </label>
              <button type="submit" class="secondary">Excel</button>
            </form>
          </div>
          <div class="grid two tx-filters" style="margin-bottom: 0.5rem;">
            <label class="field">
              <span>Categoria</span>
              <select id="filter-category">
                <option value="">Todas</option>
                <% categories.forEach((cat) => { %>
                  <option value="<%= cat.id %>"><%= cat.nome %> (<%= cat.tipo === 'income' ? 'Receita' : 'Despesa' %>)</option>
                <% }) %>
              </select>
            </label>
            <label class="field filter-date">
              <span>De</span>
              <input id="filter-from" type="date" />
            </label>
            <label class="field filter-date">
              <span>Ate</span>
              <input id="filter-to" type="date" />
            </label>
            <button type="button" class="secondary filter-clear" id="filter-clear">Limpar filtros</button>
          </div>
          <% if (recent.length === 0) { %>
            <p class="muted">Sem movimentos ainda.</p>
          <% } else { %>
            <ul class="list" id="tx-list">
              <% recent.forEach((row) => { %>
                <li data-id="<%= row.id %>" data-type="<%= row.tipo %>" data-amount="<%= row.valor %>" data-date="<%= row.data_ocorrencia %>" data-desc="<%= row.descricao || '' %>" data-category="<%= row.categoria_id || '' %>">
                  <span>
                    <span class="date" data-date="<%= row.data_ocorrencia %>"></span> - <%= row.categoria_nome || 'Sem categoria' %>
                    <% if (row.descricao) { %>
                      <span class="tx-desc"> · <%= row.descricao %></span>
                    <% } %>
                    <% if (row.document_id) { %>
                      <a class="doc-link" href="/documents/<%= row.document_id %>">Documento</a>
                    <% } %>
                  </span>
                  <div class="tx-actions">
                    <strong class="<%= row.tipo === 'income' ? 'income' : 'expense' %>">
                      <%= row.tipo === 'income' ? '+' : '-' %><%= Number(row.valor).toFixed(2) %> €
                    </strong>
                    <button type="button" class="icon-btn edit-tx">Editar</button>
                    <form method="POST" action="/transactions/void" class="inline-form">
                      <input type="hidden" name="id" value="<%= row.id %>" />
                      <button type="submit" class="icon-btn">Anular</button>
                    </form>
                    <form method="POST" action="/transactions/delete" class="inline-form">
                      <input type="hidden" name="id" value="<%= row.id %>" />
                      <button type="submit" class="icon-btn danger">Apagar</button>
                    </form>
                  </div>
                </li>
              <% }) %>
            </ul>
            <div class="pagination" id="tx-pagination">
              <% const base = categoryId ? `&category_id=${categoryId}` : ''; %>
              <a class="icon-btn <%= page <= 1 ? 'disabled' : '' %>" href="/transactions?page=<%= Math.max(1, page - 1) %><%= base %>">Anterior</a>
              <span class="tx-desc">Pagina <%= page %> de <%= totalPages %></span>
              <a class="icon-btn <%= page >= totalPages ? 'disabled' : '' %>" href="/transactions?page=<%= Math.min(totalPages, page + 1) %><%= base %>">Seguinte</a>
            </div>
          <% } %>
        </div>
      </section>
    </main>

    <button class="mobile-add" type="button" id="open-tx" aria-label="Adicionar movimento">
      <i class="fa-solid fa-plus"></i>
    </button>

    <div class="modal-overlay" id="tx-modal">
      <div class="modal">
        <div class="modal-header">
          <h2>Novo movimento</h2>
          <button class="modal-close" type="button" id="close-tx">Fechar</button>
        </div>
        <form method="POST" action="/transactions" enctype="multipart/form-data" class="stack" id="tx-form-mobile">
          <label class="field">
            <span>Tipo</span>
            <select name="type" id="tx-type-mobile" required>
              <option value="expense">Despesa</option>
              <option value="income">Receita</option>
            </select>
          </label>
          <label class="field">
            <span>Valor</span>
            <input name="amount" type="number" step="0.01" required />
          </label>
          <label class="field">
            <span>Data</span>
            <input name="date" id="tx-date-mobile" type="date" required />
          </label>
          <label class="field">
            <span>Descricao</span>
            <input name="description" type="text" />
          </label>
          <label class="field">
            <span>Categoria</span>
            <input type="text" id="tx-category-filter-mobile" placeholder="Pesquisar categoria..." />
            <select name="category_id" id="tx-category-mobile" required>
              <option value="">Sem categoria</option>
              <% categories.forEach((cat) => { %>
                <option value="<%= cat.id %>"><%= cat.nome %> (<%= cat.tipo === 'income' ? 'Receita' : 'Despesa' %>)</option>
              <% }) %>
            </select>
          </label>
          <label class="field">
            <span>Documento</span>
            <input name="documento" type="file" />
          </label>
          <button type="submit">Guardar</button>
        </form>
      </div>
    </div>

    <div class="modal-overlay" id="tx-edit-modal">
      <div class="modal">
        <div class="modal-header">
          <h2>Editar movimento</h2>
          <button class="modal-close" type="button" id="close-edit">Fechar</button>
        </div>
        <form method="POST" action="/transactions/update" enctype="multipart/form-data" class="stack" id="tx-edit-form">
          <input type="hidden" name="id" id="edit-id" />
          <label class="field">
            <span>Tipo</span>
            <select name="type" id="edit-type" required>
              <option value="expense">Despesa</option>
              <option value="income">Receita</option>
            </select>
          </label>
          <label class="field">
            <span>Valor</span>
            <input name="amount" id="edit-amount" type="number" step="0.01" required />
          </label>
          <label class="field">
            <span>Data</span>
            <input name="date" id="edit-date" type="date" required />
          </label>
          <label class="field">
            <span>Descricao</span>
            <input name="description" id="edit-desc" type="text" />
          </label>
          <label class="field">
            <span>Categoria</span>
            <input type="text" id="edit-category-filter" placeholder="Pesquisar categoria..." />
            <select name="category_id" id="edit-category">
              <option value="">Sem categoria</option>
              <% categories.forEach((cat) => { %>
                <option value="<%= cat.id %>"><%= cat.nome %> (<%= cat.tipo === 'income' ? 'Receita' : 'Despesa' %>)</option>
              <% }) %>
            </select>
          </label>
          <label class="field">
            <span>Documento</span>
            <input name="documento" type="file" />
          </label>
          <button type="submit">Guardar</button>
        </form>
      </div>
    </div>

    <script>
      const dateInputs = [document.getElementById('tx-date'), document.getElementById('tx-date-mobile')];
      const today = new Date();
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      const exportMonth = document.getElementById('export-month');
      const exportYear = document.getElementById('export-year');
      dateInputs.forEach((input) => {
        if (input) input.value = `${yyyy}-${mm}-${dd}`;
      });
      if (exportMonth) exportMonth.value = `${yyyy}-${mm}`;
      if (exportYear) exportYear.value = String(yyyy);

      const dateFormatter = new Intl.DateTimeFormat('pt-PT', {
        day: '2-digit',
        month: '2-digit',
        year: 'numeric',
      });
      document.querySelectorAll('.date').forEach((el) => {
        const raw = el.dataset.date;
        const parsed = raw ? new Date(raw) : null;
        el.textContent = parsed ? dateFormatter.format(parsed) : '';
      });

      const params = new URLSearchParams(window.location.search);
      const quick = params.get('quick');
      if (quick === 'expense' || quick === 'income') {
        const desktopType = document.getElementById('tx-type');
        const mobileType = document.getElementById('tx-type-mobile');
        if (desktopType) desktopType.value = quick;
        if (mobileType) mobileType.value = quick;
        const isMobile = window.matchMedia && window.matchMedia('(max-width: 720px)').matches;
        if (isMobile && modal) modal.classList.add('open');
        const form = document.getElementById('tx-form');
        if (!isMobile && form) form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      const filterCategory = document.getElementById('filter-category');
      const filterFrom = document.getElementById('filter-from');
      const filterTo = document.getElementById('filter-to');
      const filterClear = document.getElementById('filter-clear');
      const pagination = document.getElementById('tx-pagination');

      const applyFilters = () => {
        const cat = filterCategory ? filterCategory.value : '';
        const from = filterFrom && filterFrom.value ? new Date(filterFrom.value) : null;
        const to = filterTo && filterTo.value ? new Date(filterTo.value) : null;
        if (to) to.setHours(23, 59, 59, 999);
        let visible = 0;
        document.querySelectorAll('#tx-list li').forEach((li) => {
          const liCat = li.dataset.category || '';
          const rawDate = li.dataset.date ? new Date(li.dataset.date) : null;
          const okCat = !cat || String(liCat) === String(cat);
          const okFrom = !from || (rawDate && rawDate >= from);
          const okTo = !to || (rawDate && rawDate <= to);
          const show = okCat && okFrom && okTo;
          li.style.display = show ? '' : 'none';
          if (show) visible += 1;
        });
        if (pagination) pagination.style.display = cat || from || to ? 'none' : '';
      };

      if (filterCategory) filterCategory.addEventListener('change', applyFilters);
      if (filterFrom) filterFrom.addEventListener('change', applyFilters);
      if (filterTo) filterTo.addEventListener('change', applyFilters);
      if (filterClear) {
        filterClear.addEventListener('click', () => {
          if (filterCategory) filterCategory.value = '';
          if (filterFrom) filterFrom.value = '';
          if (filterTo) filterTo.value = '';
          applyFilters();
        });
      }

      const openBtn = document.getElementById('open-tx');
      const modal = document.getElementById('tx-modal');
      const closeBtn = document.getElementById('close-tx');
      if (openBtn && modal && closeBtn) {
        openBtn.addEventListener('click', () => modal.classList.add('open'));
        closeBtn.addEventListener('click', () => modal.classList.remove('open'));
        modal.addEventListener('click', (e) => {
          if (e.target === modal) modal.classList.remove('open');
        });
        window.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') modal.classList.remove('open');
        });
      }

      const editModal = document.getElementById('tx-edit-modal');
      const closeEdit = document.getElementById('close-edit');
      document.querySelectorAll('.edit-tx').forEach((btn) => {
        btn.addEventListener('click', () => {
          const li = btn.closest('li');
          if (!li) return;
          document.getElementById('edit-id').value = li.dataset.id;
          document.getElementById('edit-type').value = li.dataset.type;
          document.getElementById('edit-amount').value = li.dataset.amount;
          document.getElementById('edit-desc').value = li.dataset.desc || '';
          document.getElementById('edit-date').value = li.dataset.date ? li.dataset.date.slice(0, 10) : '';
          document.getElementById('edit-category').value = li.dataset.category || '';
          if (editModal) editModal.classList.add('open');
        });
      });
      if (closeEdit && editModal) {
        closeEdit.addEventListener('click', () => editModal.classList.remove('open'));
        editModal.addEventListener('click', (e) => {
          if (e.target === editModal) editModal.classList.remove('open');
        });
      }

      const wireCategoryFilter = (inputId, selectId) => {
        const input = document.getElementById(inputId);
        const select = document.getElementById(selectId);
        if (!input || !select) return;
        const options = Array.from(select.options).map(opt => ({
          value: opt.value,
          text: opt.textContent,
        }));
        input.addEventListener('input', () => {
          const q = input.value.trim().toLowerCase();
          select.innerHTML = '';
          options.forEach((opt) => {
            if (!q || opt.text.toLowerCase().includes(q)) {
              const optionEl = document.createElement('option');
              optionEl.value = opt.value;
              optionEl.textContent = opt.text;
              select.appendChild(optionEl);
            }
          });
        });
      };

      wireCategoryFilter('tx-category-filter', 'tx-category');
      wireCategoryFilter('tx-category-filter-mobile', 'tx-category-mobile');
      wireCategoryFilter('edit-category-filter', 'edit-category');
    </script>
    <script src="/js/documents.js"></script>
  </body>
</html>
