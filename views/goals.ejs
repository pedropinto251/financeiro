<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Objetivos' %></title>
    <link rel="stylesheet" href="/css/app.css" />
    <script src="/js/fontawesome.min.js" defer></script>
  </head>
  <body>
    <header class="topbar">
      <div>
        <h1>Objetivos</h1>
        <p class="muted">Acompanhe as suas poupancas.</p>
      </div>
    </header>

    <main class="container">
      <%- include('partials/nav') %>

      <% if (notice) { %>
        <div class="notice"><%= notice %></div>
      <% } %>
      <% if (error) { %>
        <div class="error-box"><%= error %></div>
      <% } %>

      <section class="grid cards">
        <div class="card">
          <h2>Saldo corrente</h2>
          <p class="value"><%= summary.available.toFixed(2) %> €</p>
          <p class="muted">Receitas: <%= summary.income.toFixed(2) %> €</p>
          <p class="muted">Despesas: <%= summary.expense.toFixed(2) %> €</p>
        </div>
        <div class="card">
          <h2>Poupanca</h2>
          <p class="value"><%= summary.allocated.toFixed(2) %> €</p>
          <p class="muted">Saldo total: <%= summary.balance.toFixed(2) %> €</p>
        </div>
      </section>

      <section class="grid two">
        <div class="card">
          <div class="tx-actions" style="margin-bottom: 0.75rem;">
            <button type="button" class="secondary" id="open-goal">Novo objetivo</button>
            <button type="button" class="secondary" id="open-allocation">Alocar poupanca</button>
          </div>

          <h2>Objetivos</h2>
          <% if (!goals || goals.length === 0) { %>
            <p class="muted">Ainda nao existem objetivos.</p>
          <% } else { %>
            <ul class="list">
              <% goals.forEach((goal) => { %>
                <% const target = Number(goal.valor_objetivo || 0); %>
                <% const allocated = Number(goal.total_alocado || 0); %>
                <% const percent = target > 0 ? Math.min(100, Math.round((allocated / target) * 100)) : 0; %>
                <li>
                  <div>
                    <strong><%= goal.nome %></strong>
                    <div class="tx-desc">Objetivo: <%= target.toFixed(2) %> €</div>
                    <% if (goal.data_objetivo) { %>
                      <div class="tx-desc">Data: <%= dateDisplay(goal.data_objetivo) %></div>
                    <% } %>
                    <div class="tx-desc">Alocado: <%= allocated.toFixed(2) %> €</div>
                    <div class="bar-track" style="margin-top:0.4rem;">
                      <span class="bar-fill" style="width:<%= percent %>%"></span>
                    </div>
                    <div class="tx-desc"><%= percent %>% completo</div>
                  </div>
                  <div class="tx-actions">
                    <button
                      type="button"
                      class="icon-btn goal-allocate"
                      data-goal="<%= goal.id %>"
                      data-name="<%= goal.nome %>"
                    >
                      Alocar
                    </button>
                    <button
                      type="button"
                      class="icon-btn goal-edit"
                      data-id="<%= goal.id %>"
                      data-name="<%= goal.nome %>"
                      data-target="<%= goal.valor_objetivo %>"
                      data-date="<%= goal.data_objetivo || '' %>"
                    >
                      Editar
                    </button>
                    <form method="POST" action="/goals/delete" class="inline-form">
                      <input type="hidden" name="goal_id" value="<%= goal.id %>" />
                      <button type="submit" class="icon-btn danger">Apagar</button>
                    </form>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>

        <div class="card">
          <h2>Alocacoes recentes</h2>
          <% if (!allocations || allocations.length === 0) { %>
            <p class="muted">Sem alocacoes.</p>
          <% } else { %>
            <ul class="list">
              <% allocations.forEach((row) => { %>
                <li>
                  <div>
                    <strong><%= row.goal_nome %></strong>
                    <div class="tx-desc"><%= dateDisplay(row.data_alocacao) %> · <%= Number(row.valor).toFixed(2) %> €</div>
                    <% if (row.nota) { %>
                      <div class="tx-desc"><%= row.nota %></div>
                    <% } %>
                  </div>
                  <div class="tx-actions">
                    <button
                      type="button"
                      class="icon-btn allocation-edit"
                      data-id="<%= row.id %>"
                      data-goal="<%= row.goal_id %>"
                      data-amount="<%= row.valor %>"
                      data-date="<%= row.data_alocacao %>"
                      data-note="<%= row.nota || '' %>"
                    >
                      Editar
                    </button>
                    <form method="POST" action="/goals/allocate/delete" class="inline-form">
                      <input type="hidden" name="allocation_id" value="<%= row.id %>" />
                      <input type="hidden" name="back_to" value="/goals" />
                      <button type="submit" class="icon-btn danger">Apagar</button>
                    </form>
                  </div>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </section>
    </main>

    <div class="modal-overlay" id="goal-modal">
      <div class="modal">
        <div class="modal-header">
          <h2>Novo objetivo</h2>
          <button type="button" class="modal-close" data-close="goal-modal">Fechar</button>
        </div>
        <form method="POST" action="/goals" class="stack">
          <label class="field">
            <span>Nome do objetivo</span>
            <input name="name" type="text" required />
          </label>
          <label class="field">
            <span>Valor objetivo (€)</span>
            <input name="target_amount" type="number" step="0.01" min="0" required />
          </label>
          <label class="field">
            <span>Data objetivo</span>
            <input name="target_date" type="date" />
          </label>
          <button type="submit">Criar objetivo</button>
        </form>
      </div>
    </div>

    <div class="modal-overlay" id="goal-edit-modal">
      <div class="modal">
        <div class="modal-header">
          <h2>Editar objetivo</h2>
          <button type="button" class="modal-close" data-close="goal-edit-modal">Fechar</button>
        </div>
        <form method="POST" action="/goals/update" class="stack" id="goal-edit-form">
          <input type="hidden" name="goal_id" id="goal-edit-id" />
          <label class="field">
            <span>Nome do objetivo</span>
            <input name="name" id="goal-edit-name" type="text" required />
          </label>
          <label class="field">
            <span>Valor objetivo (€)</span>
            <input name="target_amount" id="goal-edit-target" type="number" step="0.01" min="0" required />
          </label>
          <label class="field">
            <span>Data objetivo</span>
            <input name="target_date" id="goal-edit-date" type="date" />
          </label>
          <button type="submit">Guardar</button>
        </form>
      </div>
    </div>

    <div class="modal-overlay" id="allocation-modal">
      <div class="modal">
        <div class="modal-header">
          <h2 id="allocation-title">Alocar poupanca</h2>
          <button type="button" class="modal-close" data-close="allocation-modal">Fechar</button>
        </div>
        <form method="POST" action="/goals/allocate" class="stack" id="allocation-form">
          <input type="hidden" name="back_to" value="/goals" />
          <label class="field">
            <span>Objetivo</span>
            <select name="goal_id" id="allocation-goal" required>
              <% goals.forEach((goal) => { %>
                <option value="<%= goal.id %>"><%= goal.nome %></option>
              <% }) %>
            </select>
          </label>
          <label class="field">
            <span>Valor a alocar (€)</span>
            <input name="amount" id="allocation-amount" type="number" step="0.01" min="0.01" required />
          </label>
          <label class="field">
            <span>Data</span>
            <input name="date" id="allocation-date" type="date" required />
          </label>
          <label class="field">
            <span>Nota (opcional)</span>
            <input name="note" type="text" />
          </label>
          <button type="submit">Alocar</button>
        </form>
      </div>
    </div>

    <div class="modal-overlay" id="allocation-edit-modal">
      <div class="modal">
        <div class="modal-header">
          <h2>Editar alocacao</h2>
          <button type="button" class="modal-close" data-close="allocation-edit-modal">Fechar</button>
        </div>
        <form method="POST" action="/goals/allocate/update" class="stack" id="allocation-edit-form">
          <input type="hidden" name="back_to" value="/goals" />
          <input type="hidden" name="allocation_id" id="allocation-edit-id" />
          <label class="field">
            <span>Objetivo</span>
            <select name="goal_id" id="allocation-edit-goal" required>
              <% goals.forEach((goal) => { %>
                <option value="<%= goal.id %>"><%= goal.nome %></option>
              <% }) %>
            </select>
          </label>
          <label class="field">
            <span>Valor a alocar (€)</span>
            <input name="amount" id="allocation-edit-amount" type="number" step="0.01" min="0.01" required />
          </label>
          <label class="field">
            <span>Data</span>
            <input name="date" id="allocation-edit-date" type="date" required />
          </label>
          <label class="field">
            <span>Nota (opcional)</span>
            <input name="note" id="allocation-edit-note" type="text" />
          </label>
          <button type="submit">Guardar</button>
        </form>
      </div>
    </div>

    <script>
      const today = new Date();
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, '0');
      const dd = String(today.getDate()).padStart(2, '0');
      const allocationDate = document.getElementById('allocation-date');
      if (allocationDate) allocationDate.value = `${yyyy}-${mm}-${dd}`;

      const openGoal = document.getElementById('open-goal');
      const goalModal = document.getElementById('goal-modal');
      const goalEditModal = document.getElementById('goal-edit-modal');
      const goalEditId = document.getElementById('goal-edit-id');
      const goalEditName = document.getElementById('goal-edit-name');
      const goalEditTarget = document.getElementById('goal-edit-target');
      const goalEditDate = document.getElementById('goal-edit-date');
      const openAllocation = document.getElementById('open-allocation');
      const allocationModal = document.getElementById('allocation-modal');
      const allocationEditModal = document.getElementById('allocation-edit-modal');
      const allocationTitle = document.getElementById('allocation-title');
      const allocationSelect = document.getElementById('allocation-goal');
      const allocationAmount = document.getElementById('allocation-amount');
      const editId = document.getElementById('allocation-edit-id');
      const editGoal = document.getElementById('allocation-edit-goal');
      const editAmount = document.getElementById('allocation-edit-amount');
      const editDate = document.getElementById('allocation-edit-date');
      const editNote = document.getElementById('allocation-edit-note');
      const available = Number('<%= Number(summary.available || 0).toFixed(2) %>');

      const openModal = (modal) => modal && modal.classList.add('open');
      const closeModal = (modal) => modal && modal.classList.remove('open');

      if (openGoal && goalModal) {
        openGoal.addEventListener('click', () => openModal(goalModal));
      }

      if (openAllocation && allocationModal) {
        openAllocation.addEventListener('click', () => openModal(allocationModal));
      }

      if (allocationAmount && available > 0) {
        allocationAmount.max = available.toFixed(2);
      }

      document.querySelectorAll('.goal-allocate').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.goal;
          const name = btn.dataset.name || 'Objetivo';
          if (allocationTitle) allocationTitle.textContent = `Alocar para: ${name}`;
          if (allocationSelect) allocationSelect.value = id;
          openModal(allocationModal);
        });
      });

      document.querySelectorAll('.goal-edit').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (goalEditId) goalEditId.value = btn.dataset.id || '';
          if (goalEditName) goalEditName.value = btn.dataset.name || '';
          if (goalEditTarget) goalEditTarget.value = btn.dataset.target || '';
          if (goalEditDate) goalEditDate.value = btn.dataset.date ? btn.dataset.date.slice(0, 10) : '';
          openModal(goalEditModal);
        });
      });

      document.querySelectorAll('.allocation-edit').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (editId) editId.value = btn.dataset.id || '';
          if (editGoal) editGoal.value = btn.dataset.goal || '';
          if (editAmount) editAmount.value = btn.dataset.amount || '';
          if (editDate) editDate.value = btn.dataset.date ? btn.dataset.date.slice(0, 10) : '';
          if (editNote) editNote.value = btn.dataset.note || '';
          openModal(allocationEditModal);
        });
      });

      document.querySelectorAll('[data-close]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.dataset.close;
          closeModal(document.getElementById(id));
        });
      });

      [goalModal, goalEditModal, allocationModal, allocationEditModal].forEach((modal) => {
        if (!modal) return;
        modal.addEventListener('click', (e) => {
          if (e.target === modal) closeModal(modal);
        });
      });
      window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeModal(goalModal);
          closeModal(goalEditModal);
          closeModal(allocationModal);
          closeModal(allocationEditModal);
        }
      });
    </script>
  </body>
</html>
