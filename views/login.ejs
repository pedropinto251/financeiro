<!DOCTYPE html>
<html lang="pt">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title || 'Login' %></title>
    <link rel="stylesheet" href="/css/app.css" />
  </head>
  <body>
    <main class="login">
      <section class="card login-card">
        <h1>Entrar</h1>
        <p class="muted">Autenticacao obrigatoria para continuar.</p>

        <% if (error === 'missing') { %>
          <p class="error-box">Preenche email e password.</p>
        <% } %>
        <% if (error === 'invalid') { %>
          <p class="error-box">Credenciais invalidas.</p>
        <% } %>
        <% if (error === 'inactive') { %>
          <p class="error-box">Conta desativada.</p>
        <% } %>

        <form method="POST" action="/login<%= redirect ? `?redirect=${encodeURIComponent(redirect)}` : '' %>" class="stack">
          <label class="field">
            <span>Email</span>
            <input name="email" type="email" value="<%= email || '' %>" required />
          </label>
          <label class="field">
            <span>Password</span>
            <input name="password" type="password" required />
          </label>
          <button type="submit">Entrar</button>
        </form>
      </section>
    </main>
  </body>
</html>
